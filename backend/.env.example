# OpenAI (server-side only; never commit real keys)
OPENAI_API_KEY=replace_me
EMBEDDING_MODEL=text-embedding-3-small

# ChatGPT (OpenAI Chat Completions)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_TIMEOUT_SECONDS=120
OPENAI_MAX_OUTPUT_TOKENS=700

# Local vector index (created by scripts/build_index.py)
VECTOR_INDEX_PATH=./data/vector_index.json

# Corpus + catalog paths (defaults are fine if you keep the repo layout)
MODELS_CSV_PATH=./data/bmw_models.csv
KNOWLEDGE_DIR=./data/knowledge

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173
